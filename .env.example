APP_ENV=production
APP_VERSION=dev
APP_DATABASE_PATH=/app/data/ogniskowy-grajek.sqlite3
APP_WORK_ROOT=/app/data/work
PIPELINE_VERSION=2.0.0
RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters
MAX_VIDEO_DURATION_SECONDS=600
MAX_DOWNLOAD_BYTES=104857600
MAX_QUEUE_SIZE=8
MAX_JOBS_PER_HOUR=3
MAX_JOBS_PER_DAY=10
MAX_GLOBAL_JOBS_PER_DAY=50
JOB_TIMEOUT_SECONDS=1800
RESULT_TTL_HOURS=24
AUDIO_DEVICE=cpu
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:8b
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=
GEMINI_DAILY_BUDGET_USD=1.00
SUBTITLE_MAX_BYTES=2097152
ASR_DEVICE=cpu
ASR_MODEL_PATH=/opt/whisper-models/faster-whisper-medium
ASR_MODEL_NAME=Systran/faster-whisper-medium
ASR_MODEL_REVISION=08e178d48790749d25932bbc082711ddcfdfbc4f
ASR_TIMEOUT_SECONDS=600
