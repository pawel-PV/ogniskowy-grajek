APP_ENV=production
APP_VERSION=dev
APP_DATABASE_PATH=/app/data/ogniskowy-grajek.sqlite3
APP_WORK_ROOT=/app/data/work
PIPELINE_VERSION=1.0.0
RATE_LIMIT_SECRET=replace-with-at-least-32-random-characters
MAX_VIDEO_DURATION_SECONDS=600
MAX_DOWNLOAD_BYTES=104857600
MAX_QUEUE_SIZE=8
MAX_JOBS_PER_HOUR=3
MAX_JOBS_PER_DAY=10
MAX_GLOBAL_JOBS_PER_DAY=50
JOB_TIMEOUT_SECONDS=1800
RESULT_TTL_HOURS=24
AUDIO_DEVICE=cpu
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:8b
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_KEY=
GEMINI_API_KEY_PAID=
GEMINI_DAILY_BUDGET_USD=1.00
